# ─────────────────────────────────────────────────────────────
#  Mr. Heckles — Environment Variables Template
#  Copy this file to `.env` and fill in real values.
#  NEVER commit `.env` to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mr-heckles?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────
# Generate a strong secret: `openssl rand -hex 64`
JWT_SECRET=replace_with_a_64_char_random_hex_string
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────
# Primary frontend origin (React dev server or production domain)
CLIENT_ORIGIN=http://localhost:3000
# Comma-separated additional allowed origins (optional)
EXTRA_ORIGINS=

# ── Rate Limiting ─────────────────────────────────────────────
# (These are already defaulted in code; override here if needed)
SYNC_RATE_WINDOW_MS=900000
SYNC_RATE_MAX=10
